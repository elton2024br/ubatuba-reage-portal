# =============================================================================
# Ubatuba Reage — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# ---------- Database (MySQL/MariaDB) ----------
# Connection string for MySQL/MariaDB
# Format: mysql://user:password@host:port/database
# Code reads MYSQL_URL first, falls back to DATABASE_URL
MYSQL_URL=mysql://user:password@localhost:3306/ubatuba_reage
# DATABASE_URL=mysql://user:password@localhost:3306/ubatuba_reage

# ---------- Server Ports ----------
# Main port (Next.js frontend) — Hostinger sets this automatically
PORT=3000
# Internal port for the API server
API_PORT=8080

# ---------- Admin User (for seed script) ----------
# Required in production. In development, defaults to admin@ubatubareage.com.br / admin123
ADMIN_EMAIL=admin@ubatubareage.com.br
ADMIN_PASSWORD=

# ---------- Next.js ----------
# Public URL of the API server (used at BUILD TIME for Next.js rewrites)
# Default is http://localhost:8080 — matches API_PORT=8080
# If you change API_PORT, rebuild Next.js with this set to match
# NEXT_PUBLIC_API_URL=http://localhost:8080

# ---------- Node Environment ----------
NODE_ENV=production
